# ====================================
# Backend Environment Variables
# ====================================
# Copy this file to .env and replace the placeholder values with your actual credentials.
# Command:  cp .env.example .env

# Server port (optional, defaults to 5000)
PORT=5000

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Database → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your actual values
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/stock-news-analyzer

# HuggingFace API Token (used for FinBERT sentiment analysis)
# Get it from: https://huggingface.co/settings/tokens → New token → Read scope
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key (used for AI summaries & price predictions)
# Get it from: https://aistudio.google.com → Get API Key → Create API key
Gemini_API=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
